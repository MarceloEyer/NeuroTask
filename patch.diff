+export function getDeadlineText(daysUntilDeadline: number): string {
+  if (daysUntilDeadline === 0) {
+    return 'Hoje';
+  } else if (daysUntilDeadline === 1) {
+    return 'Amanhã';
+  } else if (daysUntilDeadline < 0) {
+    return `Atrasado ${Math.abs(daysUntilDeadline)}d`;
+  }
+  return `${daysUntilDeadline} dias`;
+}
+
 export function shouldBreakDown(task: Task): boolean {
   return task.size === 'Grande' && task.checklist.length === 0;
 }
